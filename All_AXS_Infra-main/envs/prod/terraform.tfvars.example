project  = "all-axs"
env      = "prod"
region   = "ams3"

docr_name = "all-axs-registry"

db_pg_size    = "db-s-2vcpu-4gb"
db_pg_version = "15"
db_pg_nodes   = 2
db_name       = "allaxs"
db_user       = "allaxs_app"
db_password   = "REPLACE_ME"   # required -- no default; set via tfvars or TF_VAR_db_password

redis_size    = "db-s-1vcpu-2gb"
redis_version = "7"

spaces_bucket_suffix = "assets"

domain    = "example.com"
subdomain = "app"

docr_subscription_tier = "professional"
admin_ip               = ""             # leave empty in production

app_platform_stub_images = {
  web    = "nginx:stable-alpine"
  api    = "nginxdemos/hello:plain-text"
  worker = "bash:latest"
}
