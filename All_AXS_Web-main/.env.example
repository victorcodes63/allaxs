# --- Local development (with API on localhost:8080) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
API_URL=http://localhost:8080

# Absolute site URL (SSR, sitemap, OG). On Vercel set to your deployment URL.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Demo public events (bundled data, no API for listings):
#   true   = always demo listings
#   false  = always use API for /events
#   (omit) = development → demo; production → API
# NEXT_PUBLIC_USE_DEMO_EVENTS=

# Optional: mock ticket-type Next proxies (see README)
# NEXT_PUBLIC_API_MOCK=1
