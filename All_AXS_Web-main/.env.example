# --- Local development (with API on localhost:8080) ---
# Server-side proxies (login, register, checkout, …) use API_URL, then NEXT_PUBLIC_API_BASE_URL.
# Set at least one; both is fine. The web app cannot sign in if nothing listens at this URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
API_URL=http://localhost:8080

# Absolute site URL (SSR, sitemap, OG). On Vercel set to your deployment URL.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Demo public events (bundled data, no API for listings):
#   true   = always demo listings
#   false  = always use API for /events
#   (omit) = development → demo; production → API
# Fixture cards use organizer display name "Demo Organizer" to align with API seed:demo
# (demo-organizer@allaxs.demo). Point the API at a seeded DB when demo mode is off.
# NEXT_PUBLIC_USE_DEMO_EVENTS=

# Optional: mock ticket-type Next proxies (see README)
# NEXT_PUBLIC_API_MOCK=1

# Persist demo checkout + tickets in the API/Neon (requires backend + seed; see README):
# NEXT_PUBLIC_USE_API_CHECKOUT=true
