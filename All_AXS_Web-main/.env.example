# Copy to .env.local for local development. Do not commit secrets.
# Staging/production blocks: docs/STAGING_CHECKLIST.md · Vercel: docs/VERCEL.md

# --- API (server proxies use API_URL, then NEXT_PUBLIC_API_BASE_URL) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
API_URL=http://localhost:8080

# Public site origin — SSR, sitemap, OG (should match API FRONTEND_URL on deploy)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_BASE_URL=   # legacy alias for NEXT_PUBLIC_SITE_URL

# Real API checkout + Paystack (false/omit = sessionStorage-only demo passes)
NEXT_PUBLIC_USE_API_CHECKOUT=true

# Public events: true = bundled demo fixtures; false (or omit in prod) = API catalog
NEXT_PUBLIC_USE_DEMO_EVENTS=false

# Optional: mock ticket-type Next proxies (see README)
# NEXT_PUBLIC_API_MOCK=1

# Google Sign-In (optional — must match API GOOGLE_CLIENT_ID)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
