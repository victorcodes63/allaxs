#!/bin/sh
# After a push that updates backend files under All_AXS_Backend-main/, mirror that
# subtree to https://github.com/victorcodes63/All_AXS_Backend-main (see scripts/push-backend-to-github.sh).
# Skips when the push remote is "backend" to avoid recursion.
#
# Enable once per clone: git config core.hooksPath .githooks

set -eu

remote="${1:-}"
# Git waits for the hook to read all stdin lines; exiting early without draining
# stdin can hang `git push` (e.g. when the subtree script pushes to `backend`).
if [ "$remote" = "backend" ]; then
  cat >/dev/null
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

PREFIX="All_AXS_Backend-main"
Z40=0000000000000000000000000000000000000000
should_sync=0

while read -r local_ref local_sha remote_ref remote_sha || true; do
  [ -z "${local_ref:-}" ] && continue
  if [ "$local_sha" = "$Z40" ]; then
    continue
  fi

  from=""
  to="$local_sha"
  if [ "$remote_sha" = "$Z40" ]; then
    if mb=$(git merge-base origin/main "$local_sha" 2>/dev/null); then
      from="$mb"
    elif mb=$(git merge-base origin/master "$local_sha" 2>/dev/null); then
      from="$mb"
    else
      from=$(git rev-list --max-parents=0 "$local_sha" 2>/dev/null | tail -n 1) || true
    fi
    if [ -z "$from" ]; then
      from="$to"
    fi
  else
    from="$remote_sha"
  fi

  if git diff --name-only "$from" "$to" 2>/dev/null | grep -q "^${PREFIX}/"; then
    should_sync=1
    break
  fi
done

if [ "$should_sync" -eq 1 ]; then
  echo "pre-push: ${PREFIX}/ changed in this push; syncing to backend GitHub repo..."
  sh "$REPO_ROOT/scripts/push-backend-to-github.sh"
  exit $?
fi

exit 0
