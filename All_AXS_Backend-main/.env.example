# Copy to .env for local development. Do not commit real secrets.
# Staging/production: set in Vercel (see docs/VERCEL.md and Web docs/STAGING_CHECKLIST.md).

# --- Database (use DATABASE_URL on Vercel, or individual fields locally) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/all_axs_db
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=all_axs_db
# DB_USER=postgres
# DB_PASS=postgres

NODE_ENV=development
PORT=8080

JWT_SECRET=change-me-local-only
JWT_REFRESH_SECRET=change-me-local-only

# Web app origin — email links, ticket QR URLs in PDFs (/v/...)
FRONTEND_URL=http://localhost:3000
# Production: https://www.axs.africa

# Volunteer door scanner PWA — links emailed to door volunteers
# SCANNER_APP_URL=https://scanner.axs.africa

# Ticket PDF header logo: bundled at src/assets/brand/logo-mark-white.png (no Next.js required).
# Source of truth: Web public/brand/. After brand updates: npm run sync:brand-assets
# Optional: WEB_BRAND_DIR=../All_AXS_Web-main/public/brand

# Web Push (browser notifications — generate with npm run push:vapid)
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_VAPID_SUBJECT=mailto:hello@allaxs.com

# Email (default provider: resend)
# EMAIL_PROVIDER=none
RESEND_API_KEY=
RESEND_FROM="All AXS <noreply@example.com>"
# HTML email header wordmark (optional). When unset, uses FRONTEND_URL + /brand/logo-header.png
# (served from Web public/brand/). Override for CDN:
# EMAIL_LOGO_URL=https://your-cdn.example/logo-header.png

# Paystack (test keys for staging)
PAYSTACK_SECRET_KEY=
# PAYSTACK_WEBHOOK_SECRET=
# PAYSTACK_CALLBACK_URL=http://localhost:3000/orders/payment/callback

# Daraja M-Pesa B2C (organizer payout disbursement)
# Keep disabled locally unless testing against Safaricom sandbox.
DARAJA_B2C_ENABLED=false
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_INITIATOR_NAME=
DARAJA_SECURITY_CREDENTIAL=
DARAJA_B2C_RESULT_URL=
DARAJA_B2C_QUEUE_TIMEOUT_URL=
# DARAJA_B2C_COMMAND_ID=BusinessPayment
# DARAJA_B2C_REMARKS=Organizer payout

# Optional platform fee (defaults: 0)
# PLATFORM_FEE_BPS=0
# PLATFORM_FEE_FIXED_CENTS=0
# PLATFORM_FEE_MAX_CENTS=

# SMS via Africa's Talking (optional — ticket delivery SMS when buyer phone is set)
# AT_API_KEY=
# AT_USERNAME=
# AT_SENDER_ID=
# AT_USE_SANDBOX=true
# SMS_TICKET_DELIVERY=true

# Optional Google OAuth (must match Web NEXT_PUBLIC_GOOGLE_CLIENT_ID)
# GOOGLE_CLIENT_ID=

# SMS ticket delivery (Africa's Talking — AUDIT-B2)
# WHATSAPP_PROVIDER=none
# SMS_TICKET_DELIVERY=true
# AT_API_KEY=
# AT_USERNAME=
# AT_SENDER_ID=
# AT_USE_SANDBOX=true

# WhatsApp ticket delivery (Twilio — AUDIT-B3). See docs/WHATSAPP_TICKET_DELIVERY.md
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_CONTENT_SID=
# WHATSAPP_DRY_RUN=false
# WHATSAPP_TICKET_DELIVERY=true

# Optional Redis rate limiting
# REDIS_URL=redis://localhost:6379

# Storage: local | spaces | stub (use stub on Vercel)
STORAGE_DRIVER=local

# --- Wallet passes (optional — see docs/WALLET_PASSES.md) ---
# Google Wallet: JWT save link via service account + issuer ID from Pay & Wallet Console
# GOOGLE_WALLET_ISSUER_ID=
# GOOGLE_WALLET_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Or split credentials:
# GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_WALLET_SERVICE_ACCOUNT_PRIVATE_KEY=

# Apple Wallet: Pass Type ID cert + WWDR + team ID from Apple Developer
# APPLE_WALLET_PASS_TYPE_IDENTIFIER=pass.com.allaxs.ticket
# APPLE_WALLET_TEAM_IDENTIFIER=
# APPLE_WALLET_ORGANIZATION_NAME=All AXS
# APPLE_WALLET_WWDR_CERT_PEM=
# APPLE_WALLET_SIGNER_CERT_PEM=
# APPLE_WALLET_SIGNER_KEY_PEM=
# APPLE_WALLET_SIGNER_KEY_PASSPHRASE=
# Local dev file paths (alternative to inline PEM):
# APPLE_WALLET_WWDR_CERT_PATH=./certs/AppleWWDRCAG4.pem
# APPLE_WALLET_SIGNER_CERT_PATH=./certs/signerCert.pem
# APPLE_WALLET_SIGNER_KEY_PATH=./certs/signerKey.pem

# CI / local dry run (see docs/CI_EMAIL_PDF_SMOKE.md)
# SKIP_EMAIL_PDF_SMOKE=1
# DRY_RUN=1 npm run smoke:all-emails  # delegates to npm run smoke:ci:email-pdf
