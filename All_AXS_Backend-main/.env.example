# Copy to .env for local development. Do not commit real secrets.
# Staging/production: set in Vercel (see docs/VERCEL.md and Web docs/STAGING_CHECKLIST.md).

# --- Database (use DATABASE_URL on Vercel, or individual fields locally) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/all_axs_db
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=all_axs_db
# DB_USER=postgres
# DB_PASS=postgres

NODE_ENV=development
PORT=8080

JWT_SECRET=change-me-local-only
JWT_REFRESH_SECRET=change-me-local-only

# Web app origin — email links, ticket QR URLs in PDFs (/v/...)
FRONTEND_URL=http://localhost:3000

# Ticket PDF header logo: bundled at src/assets/brand/logo-mark-white.png (no Next.js required).
# Source of truth: Web public/brand/. After brand updates: npm run sync:brand-assets
# Optional: WEB_BRAND_DIR=../All_AXS_Web-main/public/brand

# Email (default provider: resend)
# EMAIL_PROVIDER=none
RESEND_API_KEY=
RESEND_FROM="All AXS <noreply@example.com>"
# HTML email header wordmark (optional). When unset, uses FRONTEND_URL + /brand/logo-header.png
# (served from Web public/brand/). Override for CDN:
# EMAIL_LOGO_URL=https://your-cdn.example/logo-header.png

# Paystack (test keys for staging)
PAYSTACK_SECRET_KEY=
# PAYSTACK_WEBHOOK_SECRET=
# PAYSTACK_CALLBACK_URL=http://localhost:3000/orders/payment/callback

# Optional platform fee (defaults: 0)
# PLATFORM_FEE_BPS=0
# PLATFORM_FEE_FIXED_CENTS=0
# PLATFORM_FEE_MAX_CENTS=

# Optional Google OAuth (must match Web NEXT_PUBLIC_GOOGLE_CLIENT_ID)
# GOOGLE_CLIENT_ID=

# Optional Redis rate limiting
# REDIS_URL=redis://localhost:6379

# Storage: local | spaces | stub (use stub on Vercel)
STORAGE_DRIVER=local
